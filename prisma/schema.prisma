datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id              String   @id @default(cuid())
  name            String
  brand           String
  category        String
  subcategory     String   @default("")
  concerns        Json
  price           Float
  discountedPrice Float
  stock           Int
  description     String   @db.Text
  usage           String   @db.Text
  ingredients     String   @db.Text
  images          Json
  published       Boolean  @default(true)
  featured        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([createdAt])
  @@index([published])
  @@index([published, featured])
  @@index([published, category])
  @@index([published, category, subcategory])
}

model Order {
  id              String   @id @default(cuid())
  customerName    String
  customerPhone   String
  customerEmail   String?
  customerAddress String   @db.Text
  notes           String?  @db.Text
  items           Json
  total           Float
  status          String   @default("New")
  whatsappSent    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id           String   @id @default(cuid())
  name         String
  phone        String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String
  message   String   @db.Text
  status    String   @default("New")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Visitor {
  id          Int      @id @default(autoincrement())
  visitorId   String   @unique
  lastActive  DateTime
  createdAt   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  details   String   @db.Text
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  userName   String
  userEmail  String?
  userAvatar String?  @db.Text
  rating     Int
  comment    String   @db.Text
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId, approved, createdAt])
}

model Setting {
  key   String @id
  value String
}

model LegalPage {
  id             String              @id @default(cuid())
  title          String
  slug           String              @unique
  content        String
  seoTitle       String              @default("")
  seoDescription String              @default("")
  keywords       String              @default("")
  ogTitle        String              @default("")
  ogDescription  String              @default("")
  ogImage        String              @default("")
  canonical      String              @default("")
  published      Boolean             @default(false)
  isDraft        Boolean             @default(true)
  version        Int                 @default(1)
  lastUpdated    DateTime            @default(now())
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  revisions      LegalPageRevision[]

  @@index([slug])
  @@index([published])
}

model LegalPageRevision {
  id            String    @id @default(cuid())
  legalPageId   String
  legalPage     LegalPage @relation(fields: [legalPageId], references: [id], onDelete: Cascade)
  title         String
  content       String
  seoTitle      String    @default("")
  seoDescription String   @default("")
  keywords      String    @default("")
  ogTitle       String    @default("")
  ogDescription String    @default("")
  ogImage       String    @default("")
  canonical     String    @default("")
  version       Int
  savedAt       DateTime  @default(now())

  @@index([legalPageId, savedAt])
}

